# .npmrc — Next.js 16 canary + React 19 ecosystem
#
# legacy-peer-deps=true
#   Next.js 16 canary 시점에서 Radix UI, Recharts 등 일부 패키지는
#   peerDependencies에 react@^17||^18를 선언함.
#   npm ≥9는 이를 ERESOLVE로 처리하므로 이 플래그를 통해
#   npm6 방식(최적 버전 설치, peer range 무시)으로 폴백.
#   overrides 필드가 react@^19를 핀닜하므로 실제 설치는 항상 19.x.
legacy-peer-deps=true
save-exact=false
package-lock=true
