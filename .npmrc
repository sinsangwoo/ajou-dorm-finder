# .npmrc
# ─────────────────────────────────────────────────────────────────────────────
# Hoisting & peer dependency strategy for Next.js 15 + React 18 ecosystem.
#
# legacy-peer-deps=true
#   Several packages in the Radix UI / Recharts ecosystem still declare
#   peerDependencies on older React ranges (e.g. react@^17 || ^18).
#   Without this flag, npm ≥9 raises an ERESOLVE error during `npm install`.
#   This flag instructs npm to use the npm ≤6 peer-dep resolution algorithm
#   (install the best version available, ignore peer range mismatches).
#
#   This is safe here because:
#     1. React 18 is backwards-compatible with components expecting React 17.
#     2. We pin exact React versions via the `overrides` field in package.json.
#     3. CI always runs `npm install` (not `npm ci`) for clean resolution.
#
# save-exact=false
#   Keep ^ ranges in package.json so Dependabot / Renovate can propose
#   non-breaking upgrades without manual intervention.
#
legacy-peer-deps=true
save-exact=false

# Ensure package-lock.json lockfileVersion stays at v3 (npm ≥7)
# so it is compatible with Node.js 22's bundled npm.
package-lock=true
